# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OnchainKit / wallet
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# Optional Alchemy Base RPC fallback for Asset Diversity (used if Blockscout fails)
# ALCHEMY_API_KEY=
# NEXT_PUBLIC_ALCHEMY_API_KEY=
# ALCHEMY_BASE_RPC_URL=

# App URL used for deployment docs and Farcaster manifest setup
# Example: https://basequest-rewards.vercel.app
# Also used as the X OAuth redirect base (callback: /api/auth/x/callback)
NEXT_PUBLIC_APP_URL=

# X (Twitter) OAuth 2.0 — server-only, never expose to the client
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=

# Neynar — server-only (Farcaster follow verification)
NEYNAR_API_KEY=
